@echo off
REM =====================================================================
REM Script to recursively remove metadata from specific file types.
REM Target formats: Word (.doc, .docx), Excel (.xls, .xlsx), DWG, DNG.
REM Requirement: exiftool.exe must be available in the system PATH 
REM or located in the same directory as this script.
REM =====================================================================

echo Starting metadata removal process...
echo Scanning current directory and all subdirectories.
echo.

REM Execute ExifTool with the following arguments:
REM -r                  : Recursively process subdirectories
REM -all=               : Remove all metadata tags
REM -overwrite_original : Overwrite the file directly without creating a *_original backup file
REM -ext [extension]    : Target specific file extensions
REM .                   : Target the current directory (where the script is executed)

exiftool -r -all= -overwrite_original -ext doc -ext docx -ext xls -ext xlsx -ext dwg -ext dng .

echo.
echo Metadata removal successfully completed!
pause
